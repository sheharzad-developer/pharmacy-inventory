# Copy to .env.local and fill in (never commit .env.local).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Required for API routes (node-pg). First non-empty wins:
# DATABASE_URL, then POSTGRES_URL_NON_POOLING, POSTGRES_URL, POSTGRES_PRISMA_URL (Vercel Supabase integration).
#
# Prefer Session pooler (*.pooler.supabase.com:5432). Avoid db.*.supabase.co on Vercel.
DATABASE_URL=

# Temporary debugging on Vercel (remove after):
# HEALTH_DB_PROBE=true
# SHOW_AUTH_ERRORS=true   → signup/login errors include raw message in JSON
#
# Optional: strict TLS cert verification for Supabase (default is off — required for many Vercel+pg setups):
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional local Docker
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/pharmacy_inventory
