# Copy to .env.local and fill in (never commit .env.local).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Required for API routes (node-pg).
#
# Supabase + Vercel: use Session pooler URI (Dashboard → Connect → Session mode).
# Host looks like aws-0-REGION.pooler.supabase.com, port 5432 — NOT db.PROJECT.supabase.co (often blocked from Vercel).
# Optional: Transaction pooler (6543) with ?pgbouncer=true — if queries fail, switch to Session pooler.
DATABASE_URL=

# Temporary: set true on Vercel to debug DB → GET /api/health/db → remove after
# HEALTH_DB_PROBE=true

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional local Docker
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/pharmacy_inventory
