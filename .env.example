# Copy to .env.local and fill in (never commit .env.local).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Required for this app’s API routes (node-pg). Supabase → Settings → Database:
# Prefer the direct URI: postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Optional — only if you add Supabase client-side SDK later
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Do NOT put service_role or DB password in NEXT_PUBLIC_* vars.

# Optional local Docker instead of Supabase
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/pharmacy_inventory
