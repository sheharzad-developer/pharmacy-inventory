# Copy to .env.local and fill in values (never commit .env.local).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Supabase Postgres — Dashboard → Project Settings → Database
# Copy "Connection string" → URI. Password is under "Database password".
#
# For Vercel/serverless, start with the direct URI (host db.<project-ref>.supabase.co, port 5432).
# If you use the Transaction pooler (port 6543), append ?pgbouncer=true to the URL.
# If you see odd query errors on the pooler, switch back to the direct (5432) URI.
DATABASE_URL=

# Optional: local Docker Postgres instead of Supabase
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/pharmacy_inventory
